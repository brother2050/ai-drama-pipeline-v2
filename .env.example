# ============================================================
# AI 短剧管线 v2 — 环境变量配置
# ============================================================

# PostgreSQL（必须）
# 先创建数据库: CREATE DATABASE ai_drama;
AI_DRAMA_DB_DSN=postgresql://drama:drama123@127.0.0.1:5432/ai_drama

# MiMo API（语音合成 — 免费）
# 获取: https://api.xiaomimimo.com
MIMO_API_KEY=

# Seko API（影视策划案 — seko.sensetime.com）
# 获取: https://seko.sensetime.com/explore
SEKO_API_KEY=

# Redis（必选 — Celery 任务队列）
REDIS_URL=redis://localhost:6379/0

# Redis 结果后端（可选，默认与 REDIS_URL 同地址的 db1）
# REDIS_BACKEND_URL=redis://localhost:6379/1

# CORS 跨域（可选，逗号分隔多个域名）
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# HuggingFace 镜像（模型下载加速）
# HF_ENDPOINT=https://hf-mirror.com
