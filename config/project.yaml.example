# ============================================================
# AI 短剧管线 v2 — 完整配置参考
# ============================================================

project:
  name: "AI短剧"           # 项目名称
  episodes: 5              # 总集数
  fps: 24                  # 帧率
  resolution: [1280, 720]  # 分辨率
  style: "cinematic"       # 画面风格: cinematic/anime/realistic/portrait/...
  genre: "urban"           # 题材: urban/ancient/scifi/campus/noir/...

comfyui:
  url: "http://127.0.0.1:8188"   # ComfyUI 地址（支持远程 API）
  timeout: 300
  api_key: ""                     # Bearer Token（留空=无认证）

models:
  image_backend: "sd15"           # sd15 | flux
  video_backend: "animatediff"    # animatediff | cogvideox
  tts_backend: "mimo-voicedesign" # mimo-voicedesign | gpt-sovits | cosyvoice | fish-speech
  lip_sync_backend: "musetalk"    # musetalk | sadtalker | wav2lip
  music_backend: "template"       # template | musicgen | suno

  # 后端专属配置
  gpt_sovits:
    api_url: "http://127.0.0.1:9880"
  musetalk:
    api_url: "http://127.0.0.1:8080"
  sadtalker:
    api_url: "http://127.0.0.1:8082"

llm:
  enabled: false
  backend: "ollama"               # ollama | openai
  base_url: "http://localhost:11434"
  model: "qwen3:8b"

server:
  port: 8888
  host: "0.0.0.0"
  cors_origin: "*"

post_production:
  transition: "crossfade"
  transition_duration: 0.5
  bgm_volume: 0.15
  subtitle_platform: "douyin"

timeouts:
  comfyui: 300
  tts: 60
  lipsync: 120
  llm: 300
  music: 120
