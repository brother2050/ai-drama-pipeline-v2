{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "frame.png"
    }
  },
  "2": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "v1-5-pruned-emaonly.safetensors"
    }
  },
  "3": {
    "class_type": "ADE_AnimateDiffLoaderWithContext",
    "inputs": {
      "model": ["2", 0],
      "context_options": ["10", 0],
      "motion_module": "mm_sd_v15_v2.safetensors",
      "beta_schedule": "sqrt_linear (AnimateDiff)",
      "motion_scale": 1.0,
      "apply_v2_models_properly": false
    }
  },
  "4": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["1", 0],
      "vae": ["2", 2]
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "cinematic style, smooth motion, natural movement",
      "clip": ["2", 1]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "bad quality, worst quality, ugly, deformed, blurry, watermark, text",
      "clip": ["2", 1]
    }
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 15,
      "cfg": 7.5,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 0.5,
      "model": ["3", 0],
      "positive": ["5", 0],
      "negative": ["6", 0],
      "latent_image": ["4", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7", 0],
      "vae": ["2", 2]
    }
  },
  "9": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["8", 0],
      "frame_rate": 8,
      "loop_count": 0,
      "filename_prefix": "video",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  },
  "10": {
    "class_type": "ADE_StandardStaticContextOptions",
    "inputs": {
      "context_length": 16,
      "context_stride": 1,
      "context_overlap": 4,
      "closed_loop": false
    }
  }
